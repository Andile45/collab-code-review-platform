{
  "name": "collab-code-review-platform",
  "version": "1.0.0",
  "description": "Collaborative Code Review Platform API (TypeScript + Express + Postgres)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "psql $DATABASE_URL -f migrations/schema.sql && psql $DATABASE_URL -f src/seed/seed.sql",
    "lint": "eslint . --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-validator": "^6.15.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.4.2",
    "@types/pg": "^8.6.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}