# ============================================
# Server
# ============================================
PORT=4000
NODE_ENV=development

# ============================================
# Database (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=collab_code_review

# ============================================
# Authentication (JWT)
# ============================================
# REQUIRED — generate a random string, e.g.: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ============================================
# CORS
# ============================================
# Frontend URL allowed to access the API
CORS_ORIGIN=http://localhost:3000
